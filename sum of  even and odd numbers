#include <stdio.h>
int main(){
    int i, n, sumeven = 0 , sumodd = 0;
    printf("enter a number:");
    scanf("%d" ,&n);
    for(i=1; i<=n; i++)
    {
        if(i % 2 == 0)
        {
            sumeven = sumeven +i;
        }
        else{
            sumodd = sumodd +i;
        }
    }
    printf("\nsum of even numbers = %d" , sumeven);
    printf("\nsum of even numbers = %d" , sumodd);
    return 0;
}
